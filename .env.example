# Environment Configuration
# Copy this to config.php and update with your actual values

# MySQL Database
DB_HOST=localhost
DB_USER=yourdomain_yonouser
DB_PASS=your_strong_database_password
DB_NAME=yourdomain_yonoapps

# Admin Panel
ADMIN_PASSWORD=change_to_strong_password_at_least_8_chars
ADMIN_SECRET=change_to_random_secret_at_least_16_chars

# Token Settings (in seconds, default 8 hours)
TOKEN_TTL_SECONDS=28800
